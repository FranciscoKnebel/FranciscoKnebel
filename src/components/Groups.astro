---
import type { Lang } from '../types';
import ui from '../data/ui.json';
import groupsData from '../data/groups.json';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = ui[lang];
---

<section id="community" class="py-24 border-t border-slate-100 dark:border-slate-800/60">
  <div class="max-w-4xl mx-auto px-6">
    <p class="section-heading reveal">{t.sections.community}</p>

    <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 gap-4">
      {groupsData.map(group => (
        <a
          href={group.url}
          target="_blank"
          rel="noopener noreferrer"
          class="card-hover group flex items-center gap-4 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 p-4 transition-colors duration-150"
        >
          <img
            src={group.avatar}
            alt={group.name}
            width="48"
            height="48"
            class="rounded-full flex-shrink-0 border border-slate-200 dark:border-slate-700"
            loading="lazy"
          />
          <div class="min-w-0">
            <p class="text-sm font-medium text-slate-900 dark:text-slate-100
                       group-hover:text-accent-600 dark:group-hover:text-accent-400
                       transition-colors duration-150 truncate">
              {group.name}
            </p>
            <p class="text-xs text-slate-400 dark:text-slate-500 mt-0.5 line-clamp-2">
              {group.description[lang]}
            </p>
          </div>
          <svg class="w-4 h-4 flex-shrink-0 text-slate-300 dark:text-slate-600 group-hover:text-accent-500 dark:group-hover:text-accent-400 transition-colors duration-150 ml-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>
