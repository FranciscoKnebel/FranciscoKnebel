---
import type { Lang } from '../types';
import ui from '../data/ui.json';
import groupsData from '../data/groups.json';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
---

<section id="community" class="border-t border-slate-100 py-24 dark:border-slate-800/60">
  <div class="mx-auto max-w-4xl px-6">
    <p class="section-heading reveal">{t.sections.community}</p>

    <div class="reveal-stagger grid grid-cols-1 gap-4 sm:grid-cols-2">
      {
        groupsData.map((group) => (
          <a
            href={group.url}
            target="_blank"
            rel="noopener noreferrer"
            class="card-hover group flex items-center gap-4 rounded-xl border border-slate-200 bg-slate-50 p-4 transition-colors duration-150 dark:border-slate-800 dark:bg-slate-900/50"
          >
            <img
              src={group.avatar}
              alt={group.name}
              width="48"
              height="48"
              class="flex-shrink-0 rounded-full border border-slate-200 dark:border-slate-700"
              loading="lazy"
            />
            <div class="min-w-0">
              <p class="truncate text-sm font-medium text-slate-900 transition-colors duration-150 group-hover:text-accent-600 dark:text-slate-100 dark:group-hover:text-accent-400">
                {group.name}
              </p>
              <p class="mt-0.5 line-clamp-2 text-xs text-slate-400 dark:text-slate-500">
                {group.description[lang]}
              </p>
            </div>
            <svg
              class="ml-auto h-4 w-4 flex-shrink-0 text-slate-300 transition-colors duration-150 group-hover:text-accent-500 dark:text-slate-600 dark:group-hover:text-accent-400"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              />
            </svg>
          </a>
        ))
      }
    </div>
  </div>
</section>
