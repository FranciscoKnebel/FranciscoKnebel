---
import type { Lang } from '../types';
import ui from '../data/ui.json';
import experiencesData from '../data/experiences.json';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
---

<section id="experience" class="border-t border-slate-100 py-24 dark:border-slate-800/60">
  <div class="mx-auto max-w-4xl px-6">
    <p class="section-heading reveal">{t.sections.experience}</p>

    <div class="reveal-stagger mt-8 space-y-8">
      {
        experiencesData.map((exp) => (
          <article
            class={`card-hover relative border-l-2 pl-6 ${
              exp.current
                ? 'border-accent-500 dark:border-accent-400'
                : exp.placeholder
                  ? 'border-slate-200 opacity-60 dark:border-slate-700'
                  : 'border-slate-200 dark:border-slate-700'
            }`}
          >
            <div class="mb-2 flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <h3 class="text-base font-semibold text-slate-900 dark:text-slate-100">
                  {exp.role[lang]}
                </h3>
                <div class="mt-0.5 flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400">
                  {exp.companyUrl ? (
                    <a
                      href={exp.companyUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-accent-600 underline-offset-2 transition-colors duration-150 hover:underline dark:text-accent-400"
                    >
                      {exp.company}
                    </a>
                  ) : (
                    <span>{exp.company}</span>
                  )}
                  <span class="text-slate-300 dark:text-slate-600">·</span>
                  <span>{exp.location[lang]}</span>
                </div>
              </div>
              <span class="mt-0.5 whitespace-nowrap font-mono text-xs text-slate-400 sm:mt-1 dark:text-slate-500">
                {exp.period[lang]}
                {exp.current && (
                  <span class="ml-2 inline-block h-1.5 w-1.5 rounded-full bg-accent-500 align-middle dark:bg-accent-400" />
                )}
              </span>
            </div>

            <p class="text-sm leading-relaxed text-slate-500 dark:text-slate-400">
              {exp.description[lang] || (exp.placeholder ? t.experience.placeholder : '')}
            </p>

            {exp.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-1.5">
                {exp.tags.map((tag) => (
                  <span class="tag inline-flex items-center rounded-md bg-slate-200 px-2 py-0.5 text-xs font-medium dark:bg-slate-800">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>
