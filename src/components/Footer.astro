---
import type { Lang } from '../types';
import ui from '../data/ui.json';
import socials from '../data/social.json';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];

const year = new Date().getFullYear();
---

<section id="contact" class="border-t border-slate-100 py-24 dark:border-slate-800/60">
  <div class="mx-auto grid max-w-6xl gap-12 px-6 sm:grid-cols-2">
    <div class="reveal">
      <p class="section-heading">{t.contact.label}</p>
      <a
        href="mailto:contato@franciscoknebel.com"
        class="text-2xl font-bold tracking-tight text-slate-900 underline-offset-4 transition-colors duration-150 hover:text-accent-600 hover:underline sm:text-3xl dark:text-slate-100 dark:hover:text-accent-400"
      >
        contato@franciscoknebel.com
      </a>
      <p class="mt-4 max-w-md text-base leading-relaxed text-slate-500 dark:text-slate-400">
        {t.contact.blurb}
      </p>
    </div>

    <div class="reveal">
      <p class="section-heading">{t.contact.elsewhere}</p>
      <div class="flex flex-col">
        {
          socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-baseline justify-between gap-4 border-b border-slate-100 py-2.5 transition-colors duration-150 dark:border-slate-800/60"
            >
              <span class="text-xs uppercase tracking-wide text-slate-400 dark:text-slate-500">
                {s.label}
              </span>
              <span class="flex-1 truncate font-mono text-sm text-slate-600 transition-colors duration-150 group-hover:text-accent-600 dark:text-slate-300 dark:group-hover:text-accent-400">
                {s.value}
              </span>
              <span class="text-slate-300 transition-colors duration-150 group-hover:text-accent-500 dark:text-slate-600 dark:group-hover:text-accent-400">
                ↗
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<footer class="border-t border-slate-100 py-10 dark:border-slate-800/60">
  <div
    class="mx-auto flex max-w-4xl flex-col items-center justify-between gap-3 px-6 text-xs text-slate-400 sm:flex-row dark:text-slate-500"
  >
    <span>© {year} Francisco Knebel</span>
    <span class="flex items-center gap-1.5">
      <a
        href="https://github.com/FranciscoKnebel/FranciscoKnebel"
        target="_blank"
        rel="noopener noreferrer"
        class="underline underline-offset-2 transition-colors duration-150 hover:text-accent-500 dark:hover:text-accent-400"
      >
        {t.footer.source}
      </a>
    </span>
  </div>
</footer>
