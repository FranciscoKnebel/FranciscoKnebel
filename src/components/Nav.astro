---
import type { Lang } from '../types';
import ui from '../data/ui.json';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = ui[lang];

const links = [
  { label: t.nav.experience, href: '#experience' },
  { label: t.nav.research,   href: '#research'   },
  { label: t.nav.projects,   href: '#projects'   },
  { label: t.nav.community,  href: '#community'  },
  { label: t.nav.stats,      href: '#stats'      },
];
---

<header class="fixed top-0 inset-x-0 z-50">
  <nav
    class="max-w-4xl mx-auto px-6 h-14 flex items-center justify-between
           border-b border-slate-200/80 dark:border-slate-800/80
           bg-white/75 dark:bg-slate-950/75 backdrop-blur-md"
    aria-label="Main navigation"
  >
    <!-- Name -->
    <a
      href="/"
      class="font-semibold text-slate-900 dark:text-slate-100 nav-link
             focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-500 rounded"
    >
      Francisco Knebel
    </a>

    <!-- Desktop: section links + lang switcher -->
    <div class="hidden sm:flex items-center gap-6 text-sm text-slate-500 dark:text-slate-400">
      {links.map(({ label, href }) => (
        <a href={href} class="nav-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-500 rounded">
          {label}
        </a>
      ))}
      <span class="text-slate-200 dark:text-slate-700 select-none">|</span>
      <div class="flex items-center gap-1 text-xs font-mono">
        <a
          href="/"
          class:list={[
            'px-1.5 py-0.5 rounded transition-colors duration-150',
            lang === 'en'
              ? 'text-accent-600 dark:text-accent-400 font-semibold'
              : 'text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300',
          ]}
          aria-label="Switch to English"
        >EN</a>
        <span class="text-slate-300 dark:text-slate-700">/</span>
        <a
          href="/pt/"
          class:list={[
            'px-1.5 py-0.5 rounded transition-colors duration-150',
            lang === 'pt'
              ? 'text-accent-600 dark:text-accent-400 font-semibold'
              : 'text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300',
          ]}
          aria-label="Mudar para Português"
        >PT</a>
      </div>
    </div>

    <!-- Mobile: lang switcher + hamburger -->
    <div class="flex sm:hidden items-center gap-3">
      <div class="flex items-center gap-1 text-xs font-mono text-slate-400 dark:text-slate-500">
        <a
          href="/"
          class:list={[
            'px-1 py-0.5 rounded transition-colors duration-150',
            lang === 'en'
              ? 'text-accent-600 dark:text-accent-400 font-semibold'
              : 'hover:text-slate-600 dark:hover:text-slate-300',
          ]}
        >EN</a>
        <span class="text-slate-300 dark:text-slate-700">/</span>
        <a
          href="/pt/"
          class:list={[
            'px-1 py-0.5 rounded transition-colors duration-150',
            lang === 'pt'
              ? 'text-accent-600 dark:text-accent-400 font-semibold'
              : 'hover:text-slate-600 dark:hover:text-slate-300',
          ]}
        >PT</a>
      </div>

      <button
        id="menu-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="p-1.5 rounded-md text-slate-500 dark:text-slate-400
               hover:bg-slate-100 dark:hover:bg-slate-800
               transition-colors duration-150
               focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-500"
      >
        <!-- Hamburger icon (shown when menu closed) -->
        <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
        </svg>
        <!-- X icon (shown when menu open) -->
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown menu -->
  <div
    id="mobile-menu"
    class="hidden sm:hidden
           border-b border-slate-200/80 dark:border-slate-800/80
           bg-white/95 dark:bg-slate-950/95 backdrop-blur-md"
    aria-hidden="true"
  >
    <div class="max-w-4xl mx-auto px-6 py-3 flex flex-col gap-0.5">
      {links.map(({ label, href }) => (
        <a
          href={href}
          class="mobile-menu-link py-2.5 px-2 rounded-lg text-sm font-medium
                 text-slate-600 dark:text-slate-300
                 hover:bg-slate-100 dark:hover:bg-slate-800
                 hover:text-accent-600 dark:hover:text-accent-400
                 transition-colors duration-150"
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  function openMenu() {
    menu?.classList.remove('hidden');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
  }

  toggle?.addEventListener('click', () => {
    menu?.classList.contains('hidden') ? openMenu() : closeMenu();
  });

  // Close when a link is tapped
  document.querySelectorAll('.mobile-menu-link').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close on outside tap
  document.addEventListener('click', (e) => {
    const header = document.querySelector('header');
    if (header && !header.contains(e.target as Node)) closeMenu();
  });
</script>
