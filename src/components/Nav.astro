---
import type { Lang } from '../types';
import ui from '../data/ui.json';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];

const links = [
  { label: t.nav.experience, href: '#experience' },
  { label: t.nav.research, href: '#research' },
  { label: t.nav.projects, href: '#projects' },
  { label: t.nav.community, href: '#community' },
  { label: t.nav.stats, href: '#stats' },
];
---

<header class="fixed inset-x-0 top-0 z-50">
  <nav
    class="mx-auto flex h-14 max-w-4xl items-center justify-between border-b border-slate-200/80 bg-white/75 px-6 backdrop-blur-md dark:border-slate-800/80 dark:bg-slate-950/75"
    aria-label="Main navigation"
  >
    <!-- Name -->
    <a
      href="/"
      class="nav-link rounded font-semibold text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-500 dark:text-slate-100"
    >
      Francisco Knebel
    </a>

    <!-- Desktop: section links + lang switcher -->
    <div class="hidden items-center gap-6 text-sm text-slate-500 sm:flex dark:text-slate-400">
      {
        links.map(({ label, href }) => (
          <a
            href={href}
            class="nav-link rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-500"
          >
            {label}
          </a>
        ))
      }
      <span class="select-none text-slate-200 dark:text-slate-700">|</span>
      <div class="flex items-center gap-1 font-mono text-xs">
        <a
          href="/"
          class:list={[
            'rounded px-1.5 py-0.5 transition-colors duration-150',
            lang === 'en'
              ? 'font-semibold text-accent-600 dark:text-accent-400'
              : 'text-slate-400 hover:text-slate-600 dark:text-slate-500 dark:hover:text-slate-300',
          ]}
          aria-label="Switch to English">EN</a
        >
        <span class="text-slate-300 dark:text-slate-700">/</span>
        <a
          href="/pt/"
          class:list={[
            'rounded px-1.5 py-0.5 transition-colors duration-150',
            lang === 'pt'
              ? 'font-semibold text-accent-600 dark:text-accent-400'
              : 'text-slate-400 hover:text-slate-600 dark:text-slate-500 dark:hover:text-slate-300',
          ]}
          aria-label="Mudar para Português">PT</a
        >
      </div>
    </div>

    <!-- Mobile: lang switcher + hamburger -->
    <div class="flex items-center gap-3 sm:hidden">
      <div class="flex items-center gap-1 font-mono text-xs text-slate-400 dark:text-slate-500">
        <a
          href="/"
          class:list={[
            'rounded px-1 py-0.5 transition-colors duration-150',
            lang === 'en'
              ? 'font-semibold text-accent-600 dark:text-accent-400'
              : 'hover:text-slate-600 dark:hover:text-slate-300',
          ]}>EN</a
        >
        <span class="text-slate-300 dark:text-slate-700">/</span>
        <a
          href="/pt/"
          class:list={[
            'rounded px-1 py-0.5 transition-colors duration-150',
            lang === 'pt'
              ? 'font-semibold text-accent-600 dark:text-accent-400'
              : 'hover:text-slate-600 dark:hover:text-slate-300',
          ]}>PT</a
        >
      </div>

      <button
        id="menu-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="rounded-md p-1.5 text-slate-500 transition-colors duration-150 hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-500 dark:text-slate-400 dark:hover:bg-slate-800"
      >
        <!-- Hamburger icon (shown when menu closed) -->
        <svg
          id="icon-open"
          class="h-5 w-5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
        <!-- X icon (shown when menu open) -->
        <svg
          id="icon-close"
          class="hidden h-5 w-5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown menu -->
  <div
    id="mobile-menu"
    class="hidden border-b border-slate-200/80 bg-white/95 backdrop-blur-md sm:hidden dark:border-slate-800/80 dark:bg-slate-950/95"
    aria-hidden="true"
  >
    <div class="mx-auto flex max-w-4xl flex-col gap-0.5 px-6 py-3">
      {
        links.map(({ label, href }) => (
          <a
            href={href}
            class="mobile-menu-link rounded-lg px-2 py-2.5 text-sm font-medium text-slate-600 transition-colors duration-150 hover:bg-slate-100 hover:text-accent-600 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-accent-400"
          >
            {label}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  function openMenu() {
    menu?.classList.remove('hidden');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
  }

  toggle?.addEventListener('click', () => {
    menu?.classList.contains('hidden') ? openMenu() : closeMenu();
  });

  // Close when a link is tapped
  document.querySelectorAll('.mobile-menu-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close on outside tap
  document.addEventListener('click', (e) => {
    const header = document.querySelector('header');
    if (header && !header.contains(e.target as Node)) closeMenu();
  });
</script>
