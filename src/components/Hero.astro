    href: 'https://www.researchgate.net/profile/Francisco-Knebel',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.586 0c-.818 0-1.508.19-2.073.565-.563.377-.97.936-1.213 1.68a12.193 12.193 0 0 0-.32 2.973v.473h-4.98V4.4c0-1.16.23-1.94.69-2.344.46-.402 1.27-.604 2.43-.604h.21V.19C13.99.063 13.34 0 12.6 0 10.48 0 8.874.688 7.78 2.066 6.685 3.44 6.138 5.33 6.138 7.73c0 1.135.14 2.2.42 3.196.278.996.706 1.882 1.28 2.657a5.78 5.78 0 0 0 2.042 1.768c.8.42 1.713.63 2.735.63 1.118 0 2.1-.255 2.946-.765.846-.51 1.5-1.25 1.963-2.218.46-.97.69-2.13.69-3.48v-.46h-5.01v1.25h3.492c-.083 1.31-.476 2.33-1.178 3.06-.702.73-1.656 1.094-2.863 1.094-1.355 0-2.436-.5-3.24-1.5-.805-1-.208-2.5-.208-4.5 0-1.955.38-3.46 1.14-4.517.758-1.057 1.837-1.585 3.234-1.585 1.078 0 1.934.3 2.567.9.632.6 1.01 1.44 1.133 2.52h1.564c-.14-1.484-.646-2.635-1.52-3.453-.873-.818-2.077-1.227-3.612-1.227-1.04 0-1.978.23-2.815.693a6.04 6.04 0 0 0-2.066 1.932c-.557.82-.976 1.78-1.258 2.88A13.52 13.52 0 0 0 4.68 7.73c0 1.49.218 2.845.652 4.064.435 1.22 1.05 2.27 1.842 3.15.794.88 1.74 1.56 2.835 2.04 1.097.48 2.3.72 3.612.72 1.16 0 2.208-.21 3.146-.627.937-.418 1.74-.993 2.41-1.726.666-.733 1.178-1.606 1.532-2.617.356-1.012.533-2.1.533-3.266V5.69h-4.98V4.4c0-.833.136-1.467.41-1.9.27-.433.7-.65 1.29-.65.31 0 .64.04.99.122V.122A8.3 8.3 0 0 0 19.586 0z"/></svg>`,
  },
  {
    label: 'Lattes',
    href: 'http://lattes.cnpq.br/5190590589102587',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>`,
