---

<section id="about" class="flex min-h-screen items-center pt-14" aria-label="Introduction">
  <div class="mx-auto w-full max-w-4xl px-6 py-20">
    <div class="reveal">
      <p class="mb-4 font-mono text-sm tracking-wide text-accent-500 dark:text-accent-400">
        {t.hero.greeting}
      </p>
      <h1
        class="mb-4 text-5xl font-bold leading-tight tracking-tight text-slate-900 sm:text-6xl dark:text-slate-50"
      >
        Francisco Knebel
      </h1>
      <p class="mb-6 text-xl font-light text-slate-500 sm:text-2xl dark:text-slate-400">
        {t.hero.role}
        <span class="mx-2 text-slate-300 dark:text-slate-600">/</span>
        {t.hero.degree}
      </p>
      <p
        class="mb-10 max-w-xl text-base leading-relaxed text-slate-500 dark:text-slate-400"
        set:html={t.hero.bio}
      />

      <div class="flex flex-wrap items-center gap-3">
        {
          socials.map(({ label, href, icon }) => (
            <a
              href={href}
              target={href.startsWith('http') ? '_blank' : undefined}
              rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
              aria-label={label}
              class="btn flex items-center gap-2 rounded-lg border border-transparent bg-slate-100 px-3 py-2 text-sm font-medium text-slate-600 transition-colors duration-150 hover:border-slate-300 hover:text-accent-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-500 dark:bg-slate-800 dark:text-slate-300 dark:hover:border-slate-600 dark:hover:text-accent-400"
            >
              <span class="h-4 w-4 flex-shrink-0" set:html={icon} />
              <span class="hidden sm:inline">{label}</span>
            </a>
          ))
        }
      </div>
    </div>

    <div class="reveal mt-20 border-t border-slate-100 pt-8 dark:border-slate-800">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {
          stats.map(({ value, label }) => (
            <div class="text-center sm:text-left">
              <div class="text-2xl font-bold text-slate-900 dark:text-slate-100">{value}</div>
              <div class="mt-0.5 text-sm text-slate-400 dark:text-slate-500">{label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
