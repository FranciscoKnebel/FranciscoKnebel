---
import type { Lang } from '../types';
import ui from '../data/ui.json';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = ui[lang];
---

<section id="stats" class="py-24 border-t border-slate-100 dark:border-slate-800/60">
  <div class="max-w-4xl mx-auto px-6">
    <p class="section-heading reveal">{t.sections.stats}</p>

    <div class="reveal grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="rounded-xl overflow-hidden bg-slate-50 dark:bg-slate-900/50">
        <img
          src="/github-metrics.svg"
          alt="GitHub metrics overview"
          class="w-full block dark:invert-[0.05]"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="rounded-xl overflow-hidden bg-slate-50 dark:bg-slate-900/50">
        <img
          src="/metrics.plugin.calendar.svg"
          alt="GitHub contribution calendar"
          class="w-full block dark:invert-[0.05]"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
