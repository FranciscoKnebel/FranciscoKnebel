---
import type { Lang } from '../types';
import ui from '../data/ui.json';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
---

<section id="stats" class="border-t border-slate-100 py-24 dark:border-slate-800/60">
  <div class="mx-auto max-w-6xl px-6">
    <p class="section-heading reveal">{t.sections.stats}</p>

    <div class="reveal-stagger mt-8 grid grid-cols-1 gap-4 md:grid-cols-3">
      <div class="col-span-3 overflow-hidden rounded-xl bg-slate-50 dark:bg-slate-900/50">
        <img
          src="https://github-profile-summary-cards.vercel.app/api/cards/profile-details?username=FranciscoKnebel&theme=github"
          alt="GitHub metrics overview"
          class="block w-full dark:invert-[0.05]"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="col-span-1 overflow-hidden rounded-xl bg-slate-50 dark:bg-slate-900/50">
        <img
          src="https://github-readme-stats.vercel.app/api/top-langs/?username=FranciscoKnebel&layout=donut-vertical&langs_count=8&hide=html,css,tex,less,dockerfile,makefile,qmake,lex,cmake,shell,gnuplot&theme=transparent"
          alt="Most used languages"
          class="block w-full dark:invert-[0.05]"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="overflow-hidden rounded-xl bg-slate-50 md:col-span-2 dark:bg-slate-900/50">
        <img
          src="https://raw.githubusercontent.com/FranciscoKnebel/FranciscoKnebel/main/profile-gitblock.svg"
          alt="GitHub contribution calendar"
          class="block w-full dark:invert-[0.05]"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
