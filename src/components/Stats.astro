---
import type { Lang } from '../types';
import ui from '../data/ui.json';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
---

<section id="stats" class="border-t border-slate-100 py-24 dark:border-slate-800/60">
  <div class="mx-auto max-w-4xl px-6">
    <p class="section-heading reveal">{t.sections.stats}</p>

    <div class="reveal grid grid-cols-1 gap-4 md:grid-cols-2">
      <div class="overflow-hidden rounded-xl bg-slate-50 dark:bg-slate-900/50">
        <img
          src="/github-metrics.svg"
          alt="GitHub metrics overview"
          class="block w-full dark:invert-[0.05]"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="overflow-hidden rounded-xl bg-slate-50 dark:bg-slate-900/50">
        <img
          src="/metrics.plugin.calendar.svg"
          alt="GitHub contribution calendar"
          class="block w-full dark:invert-[0.05]"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
