---
import type { Lang } from '../types';
import ui from '../data/ui.json';
import projectsData from '../data/projects.json';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
---

<section id="projects" class="border-t border-slate-100 py-24 dark:border-slate-800/60">
  <div class="mx-auto max-w-4xl px-6">
    <p class="section-heading reveal">{t.sections.projects}</p>

    <div class="reveal-stagger grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        projectsData.map((project) => (
          <article class="card-hover flex flex-col rounded-xl border border-slate-200 bg-slate-50 p-5 dark:border-slate-800 dark:bg-slate-900/50">
            <div class="mb-3 flex items-start justify-between">
              <svg
                class="h-7 w-7 text-slate-300 dark:text-slate-600"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z"
                />
              </svg>
              <div class="flex gap-2">
                {project.repo && (
                  <a
                    href={project.repo}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Repository"
                    class="text-slate-300 transition-colors duration-150 hover:text-slate-600 dark:text-slate-600 dark:hover:text-slate-300"
                  >
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                    </svg>
                  </a>
                )}
                {project.url && (
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Live site"
                    class="text-slate-300 transition-colors duration-150 hover:text-slate-600 dark:text-slate-600 dark:hover:text-slate-300"
                  >
                    <svg
                      class="h-4 w-4"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                      />
                    </svg>
                  </a>
                )}
              </div>
            </div>

            <h3 class="mb-2 text-sm font-semibold text-slate-900 dark:text-slate-100">
              {project.name[lang]}
            </h3>
            <p class="flex-1 text-sm leading-relaxed text-slate-500 dark:text-slate-400">
              {project.description[lang]}
            </p>

            {project.tags.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-1.5 border-t border-slate-200 pt-4 dark:border-slate-800">
                {project.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </article>
        ))
      }
    </div>

    <p class="reveal mt-6 text-xs text-slate-400 dark:text-slate-500">
      {t.sections.moreProjects}
      <a
        href="https://github.com/FranciscoKnebel"
        target="_blank"
        rel="noopener noreferrer"
        class="underline underline-offset-2 transition-colors duration-150 hover:text-accent-500"
        >GitHub</a
      >.
    </p>
  </div>
</section>
